.venv/
__pycache__/
*.pyc
*.log
*.pid

# Local-only tooling (e.g. cloudflared binary for the tunnel) — not committed
tools/

# Editor-local settings
.vscode/

# Frontend (React + Vite). dist/ IS committed for clone-and-run (like the
# vector index); only dependencies and build caches stay out.
frontend/node_modules/
frontend/node_modules/.tmp/
*.tsbuildinfo

# SECURITY: credentials never leave this machine.
# Local admin bootstrap secrets (see secrets_local.example.py for the template).
secrets_local.py
# The SQLite DB holds user password hashes (+ sessions/chat/audit) — keep local.
data/app.db
data/app.db-wal
data/app.db-shm

# Local-only thesis document (kept out of git by request).
docs/Teza_DOKU.docx

# Committed for clone-and-run: data/corpus/ (source PDFs), data/uploads/ (working
# copies) and data/chroma_db/ (vector index). Generated Word exports and the
# credential-bearing app.db stay out of git.
data/exports/

# Legacy (pre-restructure) artifacts
data/documents/
data/chroma/
data/doku.db
